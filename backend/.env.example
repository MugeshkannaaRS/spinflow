# Copy this file to .env and fill in your secrets.
# NEVER commit .env to version control.

DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db?sslmode=require
DATABASE_SYNC_URL=postgresql://user:password@host:5432/db?sslmode=require

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
REFRESH_SECRET_KEY=
QR_SECRET_KEY=

REDIS_URL=redis://:password@localhost:6379/0

# Razorpay (optional — leave blank if not using billing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Observability (optional)
SENTRY_DSN=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
