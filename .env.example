# =============================================================================
# SpinFlow ERP — Environment Variables Reference
# =============================================================================
# Copy this file to .env in the project root (for frontend) and backend/.env
# (for backend). Fill in your actual values before starting the app.
# =============================================================================

# ── Required Backend Variables ──────────────────────────────────────────────
# The app CRASHES at startup if any of these are missing.

# PostgreSQL connection string (async). Must be a valid Supabase/RDS URL.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://spinflow:your_password@localhost:5432/spinflow_db

# Sync variant for tools that need it (alembic offline). Same credentials.
DATABASE_SYNC_URL=postgresql://spinflow:your_password@localhost:5432/spinflow_db

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters.
SECRET_KEY=your-64-char-hex-secret-key-here-must-be-at-least-32-chars

# Separate key for refresh tokens. Generate the same way.
REFRESH_SECRET_KEY=your-different-64-char-hex-refresh-secret-key-here

# Redis URL — used for rate limiting and session cache.
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# QR code signing key — any strong secret.
QR_SECRET_KEY=your-qr-signing-key-32-chars-min

# ── Optional Backend Variables ──────────────────────────────────────────────

# Debug mode. Set to "true" for local development. Never in production.
DEBUG=false

# Rate limit per minute (global default). Individual endpoints override.
RATE_LIMIT_PER_MINUTE=60

# SMTP for password reset emails. Leave empty if not using email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=SpinFlow ERP

# CORS — comma-separated allowed origins for browser API calls.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https://(.*\.ngrok(?:-free)?\.dev|.*\.onrender\.com)$

# ── Frontend Variables (VITE_ prefixed) ─────────────────────────────────────

# Backend API base URL (used by the web app to call the API).
VITE_API_BASE_URL=http://localhost:8000
